{
  "executionRoleArn": "@@EXECUTION_ROLE_ARN@@",
  "taskRoleArn": "@@TASK_ROLE_ARN@@",
  "family": "@@TASK_FAMILY@@",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "<IMAGE1_NAME>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DATABASE_URL",
          "value": "@@DATABASE_URL@@"
        },
        {
          "name": "JWT_SECRET_KEY",
          "value": "@@JWT_SECRET_KEY@@"
        },
        {
          "name": "JWT_EXPIRES_HOURS",
          "value": "@@JWT_EXPIRES_HOURS@@"
        },
        {
          "name": "SERVICE_USERNAME",
          "value": "@@SERVICE_USERNAME@@"
        },
        {
          "name": "SERVICE_PASSWORD",
          "value": "@@SERVICE_PASSWORD@@"
        },
        {
          "name": "RUN_DB_INIT",
          "value": "@@RUN_DB_INIT@@"
        },
        {
          "name": "DB_INIT_REQUIRED",
          "value": "@@DB_INIT_REQUIRED@@"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "@@AWSLOGS_GROUP@@",
          "awslogs-region": "@@AWS_REGION@@",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ]
}
