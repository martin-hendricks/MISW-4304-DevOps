{
  "executionRoleArn": "@@EXECUTION_ROLE_ARN@@",
  "taskRoleArn": "@@TASK_ROLE_ARN@@",
  "family": "@@TASK_FAMILY@@",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "<IMAGE1_NAME>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "@@AWSLOGS_GROUP@@",
          "awslogs-region": "@@AWS_REGION@@",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ]
}
