# Copy to terraform.tfvars (gitignored) and adjust.
# Never commit real secrets.

aws_region   = "us-east-1"
project_name = "blacklist-svc"
environment  = "dev"

# Deploy path: EB (ZIP) vs ECS Fargate + ALB Blue/Green + CodeDeploy + ECR.
# Same value must be exported as DEPLOYMENT_PLATFORM for ./scripts/deploy.sh
deployment_platform = "elastic_beanstalk" # or "ecs_fargate_codedeploy"

jwt_secret_key   = "replace-with-long-random-string"
service_password = "replace-with-strong-password"

# Optional overrides:
# vpc_cidr             = "10.1.0.0/16"
# eb_instance_type     = "t3.micro"
# rds_instance_class   = "db.t4g.micro"
# rds_multi_az         = false
# rds_skip_final_snapshot = true
# rds_backup_retention_period = 7   # default in dev is 0 (Free Tier); increase on a paid account

# If the Docker solution stack data source fails in your region, pin explicitly:
# solution_stack_name = "64bit Amazon Linux 2023 v4.0.0 running Docker"

# Fallback regex for Amazon Linux 2:
# solution_stack_regex = "^64bit Amazon Linux 2 v[0-9.]+ running Docker$"

# --- Elastic Beanstalk deployment policy (mismo entorno; elige UNA y aplica) ---
# Default en variables.tf: Rolling + 33% por lote (razonable con min 3 instancias).
#
# eb_deployment_policy = "AllAtOnce"
# eb_deployment_policy = "Rolling"
# eb_deployment_policy = "RollingWithAdditionalBatch"
# eb_deployment_policy = "Immutable"
#
# Ajuste de lotes (sobre todo Rolling / RollingWithAdditionalBatch):
# eb_deployment_batch_size_type  = "Percentage"  # o "Fixed"
# eb_deployment_batch_size       = "33"           # ej. 33 por ciento o 1 instancia si Fixed
#
# Tras cambiar: terraform apply -var-file=terraform.tfvars

# --- ECS + CodeDeploy (solo si deployment_platform = "ecs_fargate_codedeploy"; Blue/Green con ALB) ---
# Arquitectura Fargate vs ECR (si CannotPull: la task y la imagen deben ser amd64 O arm64, no mezcladas):
# ecs_fargate_cpu_architecture = "X86_64"  # default; ./scripts/deploy_ecs_codedeploy.sh usa linux/amd64
# ecs_fargate_cpu_architecture = "ARM64"   # el mismo script usa linux/arm64
#
# Plantillas taller: deploy/codepipeline/appspec.json y taskdef.json; build opcional buildspec.pipeline.yml.
# ecs_desired_count                       = 1   # default; 2 si quieres HA de tareas en producción
# ecs_task_cpu                           = 256
# ecs_task_memory                        = 512
# ecs_create_codedeploy_artifact_bucket  = false
#
# Blue/Green: cómo CodeDeploy mueve el tráfico prod entre target groups (elige UNA).
# ecs_codedeploy_deployment_config_name = "CodeDeployDefault.ECSAllAtOnce"                         # todo el tráfico al nuevo task set en un paso
# ecs_codedeploy_deployment_config_name = "CodeDeployDefault.ECSLinear10PercentEvery1Minutes"       # +10% cada minuto hasta 100%
# ecs_codedeploy_deployment_config_name = "CodeDeployDefault.ECSLinear10PercentEvery3Minutes"     # +10% cada 3 min hasta 100%
# ecs_codedeploy_deployment_config_name = "CodeDeployDefault.ECSCanary10Percent5Minutes"         # canary 10%, espera 5 min, resto
# ecs_codedeploy_deployment_config_name = "CodeDeployDefault.ECSCanary10Percent15Minutes"         # canary 10%, espera 15 min, resto
#
# Cambiar plataforma destruye/crea el tier de cómpute correspondiente (EB o ECS).

# --- CodeBuild / CodePipeline ya existentes en la cuenta (opcional; IAM sigue solo en la consola — data sources) ---
# manage_existing_ci_resources = false
# manage_existing_ci_resources = true  # requiere terraform import de 4 recursos (ver comentario cicd_existing.tf)
# cicd_existing_github_full_repository_id   = "tu-usuario/MISW-4304-DevOps"
# cicd_existing_github_https_url           = "https://github.com/tu-usuario/MISW-4304-DevOps"
# cicd_existing_image_repo_name           = "blacklist-svc-dev-app"  # alinear con Terraform ECR si aplica
# cicd_existing_codestar_arn_devops_pipeline    = "arn:aws:codeconnections:..."
# cicd_existing_codestar_arn_beanstalk_pipeline = "arn:aws:codeconnections:..."

