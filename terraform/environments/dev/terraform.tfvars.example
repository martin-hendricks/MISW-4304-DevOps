# Copy to terraform.tfvars (gitignored) and adjust.
# Never commit real secrets.

aws_region   = "us-east-1"
project_name = "blacklist-svc"
environment  = "dev"

# Deploy path: EB (ZIP) vs ECS Fargate + ALB Blue/Green + CodeDeploy + ECR.
# Same value must be exported as DEPLOYMENT_PLATFORM for ./scripts/deploy.sh
deployment_platform = "elastic_beanstalk" # or "ecs_fargate_codedeploy"

jwt_secret_key   = "replace-with-long-random-string"
service_password = "replace-with-strong-password"

# Optional overrides:
# vpc_cidr             = "10.1.0.0/16"
# eb_instance_type     = "t3.micro"
# rds_instance_class   = "db.t4g.micro"
# rds_multi_az         = false
# rds_skip_final_snapshot = true
# rds_backup_retention_period = 7   # default in dev is 0 (Free Tier); increase on a paid account

# If the Docker solution stack data source fails in your region, pin explicitly:
# solution_stack_name = "64bit Amazon Linux 2023 v4.0.0 running Docker"

# Fallback regex for Amazon Linux 2:
# solution_stack_regex = "^64bit Amazon Linux 2 v[0-9.]+ running Docker$"

# --- Elastic Beanstalk deployment policy (mismo entorno; elige UNA y aplica) ---
# Default en variables.tf: Rolling + 33% por lote (razonable con min 3 instancias).
#
# eb_deployment_policy = "AllAtOnce"
# eb_deployment_policy = "Rolling"
# eb_deployment_policy = "RollingWithAdditionalBatch"
# eb_deployment_policy = "Immutable"
#
# Ajuste de lotes (sobre todo Rolling / RollingWithAdditionalBatch):
# eb_deployment_batch_size_type  = "Percentage"  # o "Fixed"
# eb_deployment_batch_size       = "33"           # ej. 33 por ciento o 1 instancia si Fixed
#
# Tras cambiar: terraform apply -var-file=terraform.tfvars

# --- ECS + CodeDeploy (solo si deployment_platform = "ecs_fargate_codedeploy") ---
# ecs_desired_count                   = 2
# ecs_task_cpu                        = 256
# ecs_task_memory                     = 512
# ecs_create_codedeploy_artifact_bucket = false
# Cambiar plataforma destruye/crea el tier de cómpute correspondiente (EB o ECS).

